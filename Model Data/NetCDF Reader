""" Reads and plots a NetCDF file to make sure the data is loaded correctly.
"""

import xarray as xr
import matplotlib.pyplot as plt
import cartopy.crs as ccrs
import cartopy.feature as cfeature
from pathlib import Path

# 1. Define the path to one of your new NetCDF files
# Adjust this filename if you want to look at a different date/time
nc_file = Path("/home/silentsquid236/Documents/GitHub/tornado-pathing-and-prediction/Model Data/netcdf_output/tornado_alley_20160401_12z.nc")

def plot_netcdf_map(filepath):
    print(f"Opening {filepath.name}...")
    
    # 2. Load the NetCDF file
    ds = xr.open_dataset(filepath)
    
    # 3. Figure out which variable names survived the CFGRIB conversion
    if "wind_speed" in ds.data_vars:
        plot_var = "wind_speed"
        cmap = "YlOrRd"  # Yellow-Orange-Red for wind
        title = "Wind Speed (m/s)"
    elif "t2m" in ds.data_vars:
        plot_var = "t2m"
        cmap = "coolwarm"
        title = "2-meter Temperature (K)"
    else:
        plot_var = list(ds.data_vars)[0]
        cmap = "viridis"
        title = f"Variable: {plot_var}"

    print(f"Plotting variable: {plot_var}")
    # Squeeze removes the 'time' dimension for a 2D plot
    data_to_plot = ds[plot_var].squeeze() 

    lat_name = "latitude" if "latitude" in ds.coords else "lat"
    lon_name = "longitude" if "longitude" in ds.coords else "lon"

    # 4. Set up the Map Projection to match the NAM model's native curve
    nam_proj = ccrs.LambertConformal(
        central_longitude=-95.0, 
        central_latitude=25.0, 
        standard_parallels=(25.0, 25.0)
    )
    
    fig = plt.figure(figsize=(10, 8))
    ax = plt.axes(projection=nam_proj)

    # Force the map to strictly zoom to our Tornado Alley box!
    ax.set_extent([-105.0, -90.0, 30.0, 45.0], crs=ccrs.PlateCarree())

    # 5. Add Map Features (Coastlines, State borders)
    ax.add_feature(cfeature.COASTLINE, linewidth=1.5)
    ax.add_feature(cfeature.BORDERS, linewidth=1.5)
    ax.add_feature(cfeature.STATES, linestyle=':', edgecolor='black')

    # 6. Plot the actual data
    # We tell Cartopy that the data coordinates are standard Lat/Lon (PlateCarree)
    mesh = ax.pcolormesh(
        ds[lon_name], 
        ds[lat_name], 
        data_to_plot, 
        transform=ccrs.PlateCarree(),
        cmap=cmap,
        shading='auto'
    )

    # 7. Add a Colorbar and Title
    cbar = plt.colorbar(mesh, orientation='vertical', pad=0.02, shrink=0.8)
    cbar.set_label(title)
    
    # Get the valid time from the dataset for the title
    if "time" in ds.coords:
        time_str = str(ds.time.values[0])[:13] + "Z" 
    else:
        time_str = "Unknown Time"
        
    plt.title(f"NAM 12km Tornado Alley Slice - {time_str}\n{title}", fontsize=14, fontweight='bold')

    # Show the plot
    plt.tight_layout()
    plt.show()
    
    # Clean up memory
    ds.close()

if __name__ == "__main__":
    if nc_file.exists():
        plot_netcdf_map(nc_file)
    else:
        print(f"Error: Could not find the file at {nc_file}")